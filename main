-- ============================================================================
--  EXECUTION ENGINES
-- ============================================================================
local function startAutofarm()
    task.spawn(function()
        local connection
        connection = RunService.Heartbeat:Connect(function()
            if not _G.AutofarmEnabled then
                if connection then connection:Disconnect() end
                return
            end
            if ClickRemote then
                if ClickRemote:IsA("RemoteEvent") then
                    for i = 1, 5 do ClickRemote:FireServer() end
                elseif ClickRemote:IsA("RemoteFunction") then
                    for i = 1, 5 do
                        task.spawn(function() ClickRemote:InvokeServer() end)
                    end
                end
            else
                warn("[NEXUS] Click Remote missing.")
                if connection then connection:Disconnect() end
            end
        end)
    end)
end

local function startAutoSpin()
    task.spawn(function()
        local connection
        connection = RunService.Heartbeat:Connect(function()
            if not _G.AutoSpinEnabled then
                if connection then connection:Disconnect() end
                return
            end
            if SpinRemote then
                if SpinRemote:IsA("RemoteEvent") then
                    SpinRemote:FireServer()
                elseif SpinRemote:IsA("RemoteFunction") then
                    task.spawn(function() SpinRemote:InvokeServer() end)
                end
            else
                warn("[NEXUS] Spin Remote missing.")
                if connection then connection:Disconnect() end
            end
            task.wait(0.05)
        end)
    end)
end

-- ============================================================================
--  TOGGLE CARD BUILDER
-- ============================================================================
local function createToggleCard(name, label, iconText, order, onToggle)
    local card = new("TextButton", {
        Name = name,
        Size = UDim2.new(1, 0, 0, 52),
        BackgroundColor3 = C.BG_CARD,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        LayoutOrder = order,
        Parent = MainContent,
    })
    new("UICorner", { CornerRadius = UDim.new(0, 10) }, card)
    new("UIStroke", { Thickness = 0.5, Color = C.BORDER, Transparency = 0.3 }, card)

    -- Icon circle
    local iconCircle = new("Frame", {
        Size = UDim2.new(0, 32, 0, 32),
        Position = UDim2.new(0, 10, 0.5, -16),
        BackgroundColor3 = C.ACCENT_DIM,
        BorderSizePixel = 0,
        Parent = card,
    })
    new("UICorner", { CornerRadius = UDim.new(1, 0) }, iconCircle)

    new("TextLabel", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = iconText,
        TextColor3 = C.TEXT_WHITE,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        Parent = iconCircle,
    })

    -- Label
    new("TextLabel", {
        Size = UDim2.new(0, 140, 0, 16),
        Position = UDim2.new(0, 52, 0, 10),
        BackgroundTransparency = 1,
        Text = label,
        TextColor3 = C.TEXT_WHITE,
        Font = Enum.Font.GothamMedium,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = card,
    })

    -- Sub-label
    new("TextLabel", {
        Size = UDim2.new(0, 140, 0, 14),
        Position = UDim2.new(0, 52, 0, 28),
        BackgroundTransparency = 1,
        Text = "Click to toggle",
        TextColor3 = C.TEXT_MUTED,
        Font = Enum.Font.Gotham,
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = card,
    })

    -- Toggle pill
    local pill = new("Frame", {
        Name = "Pill",
        Size = UDim2.new(0, 44, 0, 22),
        Position = UDim2.new(1, -56, 0.5, -11),
        BackgroundColor3 = C.RED_DIM,
        BorderSizePixel = 0,
        Parent = card,
    })
    new("UICorner", { CornerRadius = UDim.new(1, 0) }, pill)

    local pillLabel = new("TextLabel", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "OFF",
        TextColor3 = C.TEXT_WHITE,
        Font = Enum.Font.GothamBold,
        TextSize = 10,
        Parent = pill,
    })

    -- Toggle knob
    local knob = new("Frame", {
        Name = "Knob",
        Size = UDim2.new(0, 18, 0, 18),
        Position = UDim2.new(0, 2, 0.5, -9),
        BackgroundColor3 = C.TEXT_WHITE,
        BorderSizePixel = 0,
        Parent = pill,
    })
    new("UICorner", { CornerRadius = UDim.new(1, 0) }, knob)

    -- Hover effects
    card.MouseEnter:Connect(function()
        TweenService:Create(card, FAST_TWEEN, { BackgroundColor3 = C.BG_CARD_HOVER }):Play()
    end)
    card.MouseLeave:Connect(function()
        TweenService:Create(card, FAST_TWEEN, { BackgroundColor3 = C.BG_CARD }):Play()
    end)

    -- Toggle logic
    local state = false
    card.MouseButton1Click:Connect(function()
        state = not state
        onToggle(state)
        if state then
            TweenService:Create(pill, FAST_TWEEN, { BackgroundColor3 = C.GREEN }):Play()
            TweenService:Create(knob, FAST_TWEEN, { Position = UDim2.new(0, 24, 0.5, -9) }):Play()
            pillLabel.Text = "ON"
            TweenService:Create(iconCircle, FAST_TWEEN, { BackgroundColor3 = C.ACCENT }):Play()
        else
            TweenService:Create(pill, FAST_TWEEN, { BackgroundColor3 = C.RED_DIM }):Play()
            TweenService:Create(knob, FAST_TWEEN, { Position = UDim2.new(0, 2, 0.5, -9) }):Play()
            pillLabel.Text = "OFF"
            TweenService:Create(iconCircle, FAST_TWEEN, { BackgroundColor3 = C.ACCENT_DIM }):Play()
        end
    end)
end

