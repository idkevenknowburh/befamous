-- ============================================================================
--  EXECUTION ENGINES
-- ============================================================================
local clickCount = 0

local function startAutofarm()
    print("[BEFAMOUS] startAutofarm() called")
    task.spawn(function()
        print("[BEFAMOUS] autofarm thread spawned, _G.AutofarmEnabled =", _G.AutofarmEnabled)
        while _G.AutofarmEnabled do
            if ClickRemote then
                local ok, err = pcall(function()
                    -- Print remote info only first 3 clicks, then every 20th
                    if clickCount < 3 or clickCount % 20 == 0 then
                        print("[BEFAMOUS] ClickRemote -- Class:", ClickRemote.ClassName, "| Name:", ClickRemote.Name, "| Parent:", ClickRemote.Parent and ClickRemote.Parent.Name or "nil", "| click #", clickCount)
                    end
                    if ClickRemote:IsA("RemoteEvent") then
                        ClickRemote:FireServer()
                        clickCount = clickCount + 1
                    elseif ClickRemote:IsA("RemoteFunction") then
                        task.spawn(function()
                            local ok2, ret = pcall(function() return ClickRemote:InvokeServer() end)
                            if not ok2 or clickCount < 5 then
                                print("[BEFAMOUS] InvokeServer -- ok:", ok2, "| return:", tostring(ret))
                            end
                        end)
                        clickCount = clickCount + 1
                    else
                        print("[BEFAMOUS] ClickRemote is NEITHER RemoteEvent nor RemoteFunction! Class:", ClickRemote.ClassName)
                        _G.AutofarmEnabled = false
                    end
                end)
                if not ok then
                    print("[BEFAMOUS] !!! FIRE ERROR:", err)
                end
            else
                print("[BEFAMOUS] ClickRemote is NIL -- cannot farm")
                _G.AutofarmEnabled = false
            end
            task.wait(0.1)
        end
        print("[BEFAMOUS] autofarm loop ENDED. Total clicks fired:", clickCount)
    end)
end

local function startAutoSpin()
    task.spawn(function()
        while _G.AutoSpinEnabled do
            if SpinRemote then
                pcall(function()
                    if SpinRemote:IsA("RemoteEvent") then
                        SpinRemote:FireServer()
                    elseif SpinRemote:IsA("RemoteFunction") then
                        task.spawn(function() SpinRemote:InvokeServer() end)
                    end
                end)
            else
                warn("[BEFAMOUS] Spin Remote not found -- cannot spin.")
                _G.AutoSpinEnabled = false
            end
            task.wait(1) -- 1 spin/sec
        end
    end)
end

