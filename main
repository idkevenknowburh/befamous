-- ============================================================================
--  TAB SYSTEM
-- ============================================================================
local activeTab = "main"
local tabButtons = {}
local tabFrames = {}

local function createTabButton(name, label, order)
    local btn = new("TextButton", {
        Name = name .. "Tab",
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Text = label,
        TextColor3 = C.TEXT_SECONDARY,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        LayoutOrder = order,
        AutoButtonColor = false,
        Parent = TabContainer,
    })
    new("UICorner", { CornerRadius = UDim.new(0, 6) }, btn)
    new("UIPadding", { PaddingLeft = UDim.new(0, 10) }, btn)

    local indicator = new("Frame", {
        Size = UDim2.new(0, 3, 0.6, 0),
        Position = UDim2.new(0, 0, 0.2, 0),
        BackgroundColor3 = C.ACCENT,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = btn,
    })
    new("UICorner", { CornerRadius = UDim.new(0, 2) }, indicator)

    tabButtons[name] = { button = btn, indicator = indicator }

    btn.MouseEnter:Connect(function()
        if activeTab ~= name then
            btn.BackgroundTransparency = 0.5
            btn.BackgroundColor3 = C.TAB_HOVER
        end
    end)
    btn.MouseLeave:Connect(function()
        if activeTab ~= name then
            btn.BackgroundTransparency = 1
        end
    end)

    btn.MouseButton1Click:Connect(function()
        activeTab = name
        for tName, tData in pairs(tabButtons) do
            if tName == name then
                tData.button.BackgroundColor3 = C.TAB_ACTIVE
                tData.button.BackgroundTransparency = 0
                tData.button.TextColor3 = C.TEXT_WHITE
                tData.indicator.BackgroundTransparency = 0
            else
                tData.button.BackgroundTransparency = 1
                tData.button.TextColor3 = C.TEXT_SECONDARY
                tData.indicator.BackgroundTransparency = 1
            end
        end
        for fName, fData in pairs(tabFrames) do
            fData.Visible = (fName == name)
        end
    end)

    return btn
end

createTabButton("main", "Main", 1)
createTabButton("credits", "Credits", 2)

tabButtons["main"].button.BackgroundColor3 = C.TAB_ACTIVE
tabButtons["main"].button.BackgroundTransparency = 0
tabButtons["main"].button.TextColor3 = C.TEXT_WHITE
tabButtons["main"].indicator.BackgroundTransparency = 0

