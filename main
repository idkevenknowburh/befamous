local CLOSE_TWEEN = TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
local FAST_TWEEN  = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local TOGGLE_POP  = TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

