-- ============================================================================
--  TAB SYSTEM
-- ============================================================================
local activeTab = "main"
local tabButtons = {}
local tabFrames = {}

local function createTabButton(name, label, order)
    local btn = new("TextButton", {
        Name = name .. "Tab",
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = C.TAB_INACTIVE,
        BorderSizePixel = 0,
        Text = "  " .. label,
        TextColor3 = C.TEXT_DIM,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        LayoutOrder = order,
        AutoButtonColor = false,
        Parent = TabContainer,
    })
    new("UICorner", { CornerRadius = UDim.new(0, 8) }, btn)

    local accent = new("Frame", {
        Name = "Accent",
        Size = UDim2.new(0, 3, 0.7, 0),
        Position = UDim2.new(0, 0, 0.15, 0),
        BackgroundColor3 = C.ACCENT,
        BorderSizePixel = 0,
        Visible = false,
        Parent = btn,
    })
    new("UICorner", { CornerRadius = UDim.new(0, 2) }, accent)

    tabButtons[name] = { button = btn, accent = accent }

    btn.MouseButton1Click:Connect(function()
        activeTab = name
        for tName, tData in pairs(tabButtons) do
            if tName == name then
                tData.accent.Visible = true
                TweenService:Create(tData.button, FAST_TWEEN, {
                    BackgroundColor3 = C.TAB_ACTIVE_BG,
                    TextColor3 = C.TEXT_WHITE,
                }):Play()
            else
                tData.accent.Visible = false
                TweenService:Create(tData.button, FAST_TWEEN, {
                    BackgroundColor3 = C.TAB_INACTIVE,
                    TextColor3 = C.TEXT_DIM,
                }):Play()
            end
        end
        for fName, fData in pairs(tabFrames) do
            fData.Visible = (fName == name)
        end
    end)

    return btn
end

createTabButton("main", "Main", 1)
createTabButton("credits", "Credits", 2)

-- Activate default tab
tabButtons["main"].accent.Visible = true
tabButtons["main"].button.BackgroundColor3 = C.TAB_ACTIVE_BG
tabButtons["main"].button.TextColor3 = C.TEXT_WHITE

