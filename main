-- ============================================================================
--  EXECUTION ENGINES
-- ============================================================================
local function startAutofarm()
    task.spawn(function()
        local connection
        local phoneCheckTimer = 0

        connection = RunService.Heartbeat:Connect(function(dt)
            if not _G.AutofarmEnabled then
                if connection then connection:Disconnect() end
                return
            end

            -- Core click loop
            if ClickRemote then
                if ClickRemote:IsA("RemoteEvent") then
                    for i = 1, 5 do ClickRemote:FireServer() end
                elseif ClickRemote:IsA("RemoteFunction") then
                    for i = 1, 5 do
                        task.spawn(function() ClickRemote:InvokeServer() end)
                    end
                end
            else
                warn("[NEXUS] Click Remote missing.")
                if connection then connection:Disconnect() end
            end

            -- Auto phone upgrade check every 3 seconds
            phoneCheckTimer = phoneCheckTimer + dt
            if phoneCheckTimer >= 3 then
                phoneCheckTimer = 0
                equipBestPhone()
            end
        end)
    end)
end

local function startAutoSpin()
    task.spawn(function()
        local connection
        connection = RunService.Heartbeat:Connect(function()
            if not _G.AutoSpinEnabled then
                if connection then connection:Disconnect() end
                return
            end
            if SpinRemote then
                if SpinRemote:IsA("RemoteEvent") then
                    SpinRemote:FireServer()
                elseif SpinRemote:IsA("RemoteFunction") then
                    task.spawn(function() SpinRemote:InvokeServer() end)
                end
            else
                warn("[NEXUS] Spin Remote missing.")
                if connection then connection:Disconnect() end
            end
            task.wait(0.05)
        end)
    end)
end

-- ============================================================================
--  STATS UPDATER
-- ============================================================================
local function formatNumber(n)
    if n >= 1e9 then
        return string.format("%.1fB", n / 1e9)
    elseif n >= 1e6 then
        return string.format("%.1fM", n / 1e6)
    elseif n >= 1e3 then
        return string.format("%.1fK", n / 1e3)
    end
    return tostring(math.floor(n))
end

task.spawn(function()
    while true do
        task.wait(1)

        -- Update followers
        local followers = getFollowers()
        if followers > 0 then
            FollowersLabel.Text = formatNumber(followers)
        end

        -- Update current phone from data cache
        pcall(function()
            local controller = ReplicatedStorage.Controllers.PhonesController
            if controller then
                local mod = require(controller)
                if mod and mod.DataCache then
                    local pdata = mod.DataCache[LocalPlayer]
                    if pdata and pdata.Data then
                        local equipped = pdata.Data.EquippedPhone or ""
                        if equipped ~= "" then
                            PhoneLabel.Text = "Phone #" .. equipped
                            lastEquippedPhone = equipped
                        end
                    end
                end
            end
        end)

        -- Update status
        if _G.AutofarmEnabled then
            StatusLabel.Text = "FARMING"
            StatusLabel.TextColor3 = C.ACCENT
        elseif _G.AutoSpinEnabled then
            StatusLabel.Text = "SPINNING"
            StatusLabel.TextColor3 = C.ACCENT_BLUE
        else
            StatusLabel.Text = "IDLE"
            StatusLabel.TextColor3 = C.TEXT_MUTED
        end
    end
end)

-- ============================================================================
--  TOGGLE CARD BUILDER
-- ============================================================================
local function createToggleCard(name, label, description, order, onToggle)
    local card = new("Frame", {
        Size = UDim2.new(1, 0, 0, 54),
        BackgroundColor3 = C.BG_CARD,
        BorderSizePixel = 0,
        LayoutOrder = order,
        Parent = MainContent,
    })
    new("UICorner", { CornerRadius = UDim.new(0, 6) }, card)

    card.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            TweenService:Create(card, FAST_TWEEN, { BackgroundColor3 = C.BG_CARD_HOVER }):Play()
        end
    end)
    card.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            TweenService:Create(card, FAST_TWEEN, { BackgroundColor3 = C.BG_CARD }):Play()
        end
    end)

    new("TextLabel", {
        Size = UDim2.new(1, -70, 0, 18),
        Position = UDim2.new(0, 14, 0, 10),
        BackgroundTransparency = 1,
        Text = label,
        TextColor3 = C.TEXT_PRIMARY,
        Font = Enum.Font.GothamMedium,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = card,
    })

    new("TextLabel", {
        Size = UDim2.new(1, -70, 0, 14),
        Position = UDim2.new(0, 14, 0, 30),
        BackgroundTransparency = 1,
        Text = description,
        TextColor3 = C.TEXT_MUTED,
        Font = Enum.Font.Gotham,
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = card,
    })

    local track = new("TextButton", {
        Size = UDim2.new(0, 40, 0, 20),
        Position = UDim2.new(1, -56, 0.5, -10),
        BackgroundColor3 = C.TOGGLE_OFF,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        Parent = card,
    })
    new("UICorner", { CornerRadius = UDim.new(1, 0) }, track)

    local knob = new("Frame", {
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(0, 2, 0.5, -8),
        BackgroundColor3 = C.TOGGLE_KNOB,
        BorderSizePixel = 0,
        Parent = track,
    })
    new("UICorner", { CornerRadius = UDim.new(1, 0) }, knob)

    local state = false
    track.MouseButton1Click:Connect(function()
        state = not state
        onToggle(state)
        if state then
            TweenService:Create(track, FAST_TWEEN, { BackgroundColor3 = C.ACCENT }):Play()
            TweenService:Create(knob, FAST_TWEEN, { Position = UDim2.new(0, 22, 0.5, -8) }):Play()
        else
            TweenService:Create(track, FAST_TWEEN, { BackgroundColor3 = C.TOGGLE_OFF }):Play()
            TweenService:Create(knob, FAST_TWEEN, { Position = UDim2.new(0, 2, 0.5, -8) }):Play()
        end
    end)
end

-- Section label
new("TextLabel", {
    Size = UDim2.new(1, 0, 0, 16),
    BackgroundTransparency = 1,
    Text = "AUTOMATION",
    TextColor3 = C.TEXT_MUTED,
    Font = Enum.Font.GothamBold,
    TextSize = 10,
    TextXAlignment = Enum.TextXAlignment.Left,
    LayoutOrder = 3,
    Parent = MainContent,
})

-- Toggle cards (revamped descriptions)
createToggleCard("ClickToggle", "Smart Autoclicker", "Clicks + auto-equips best phone", 4, function(state)
    _G.AutofarmEnabled = state
    if state then
        startAutofarm()
        -- Do an immediate phone check on enable
        equipBestPhone()
    end
end)

createToggleCard("SpinToggle", "Auto Spin Wheel", "Spins the wheel automatically", 5, function(state)
    _G.AutoSpinEnabled = state
    if state then startAutoSpin() end
end)

