-- ============================================================================
--  DRAG ENGINE
-- ============================================================================
local dragging, dragInput, dragStart, startPos

TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

TopBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- ============================================================================
--  OPEN / CLOSE ANIMATIONS
-- ============================================================================
local isUIOpen = true

local function closeUI()
    if not isUIOpen then return end
    isUIOpen = false
    savedPosition = MainFrame.Position

    ToggleBtn.Position = UDim2.new(
        savedPosition.X.Scale, savedPosition.X.Offset + MainFrame.Size.X.Offset / 2 - 21,
        savedPosition.Y.Scale, savedPosition.Y.Offset + 30
    )

    TweenService:Create(MainFrame, CLOSE_TWEEN, {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
    }):Play()

    ToggleBtn.Visible = true
    ToggleBtn.Size = UDim2.new(0, 0, 0, 0)
    TweenService:Create(ToggleBtn, TOGGLE_POP, { Size = UDim2.new(0, 42, 0, 42) }):Play()
end

local function openUI()
    if isUIOpen then return end
    isUIOpen = true

    TweenService:Create(ToggleBtn, FAST_TWEEN, { Size = UDim2.new(0, 0, 0, 0) }):Play()
    task.delay(0.15, function() ToggleBtn.Visible = false end)

    MainFrame.Size = UDim2.new(0, 0, 0, 0)
    MainFrame.BackgroundTransparency = 1
    MainFrame.Position = UDim2.new(
        ToggleBtn.Position.X.Scale, ToggleBtn.Position.X.Offset + 21 - 230,
        ToggleBtn.Position.Y.Scale, ToggleBtn.Position.Y.Offset - 170
    )

    TweenService:Create(MainFrame, OPEN_TWEEN, {
        Size = UDim2.new(0, 460, 0, 340),
        BackgroundTransparency = 0,
    }):Play()
end

CloseBtn.MouseButton1Click:Connect(closeUI)
ToggleBtn.MouseButton1Click:Connect(openUI)
