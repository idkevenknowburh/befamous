-- Toggle cards
createToggleCard("ClickToggle", "Smart Autoclicker", "Automatically clicks for you", 2, function(state)
    print("[BEFAMOUS] Toggle clicked -- state:", state)
    _G.AutofarmEnabled = state
    print("[BEFAMOUS] _G.AutofarmEnabled set to:", _G.AutofarmEnabled)
    if state then
        clickCount = 0
        print("[BEFAMOUS] About to call startAutofarm()")
        startAutofarm()
        print("[BEFAMOUS] startAutofarm() returned (loop runs in thread)")
    else
        print("[BEFAMOUS] Autofarm disabled by toggle")
    end
end)

createToggleCard("SpinToggle", "Auto Spin Wheel", "Spins the wheel automatically", 3, function(state)
    _G.AutoSpinEnabled = state
    if state then startAutoSpin() end
end)

