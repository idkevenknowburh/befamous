-- ============================================================================
--  DUPLICATE PREVENTION — destroy old GUI if re-executed
-- ============================================================================
local CoreGui = game:GetService("CoreGui")
local oldGui = CoreGui:FindFirstChild("NexusMetricsUI")
if oldGui then
    oldGui:Destroy()
end

-- ============================================================================
--  REMOTE LOCATOR
-- ============================================================================
local RemotesFolder = ReplicatedStorage:FindFirstChild("Utilities")
    and ReplicatedStorage.Utilities:FindFirstChild("Network")
    and ReplicatedStorage.Utilities.Network:FindFirstChild("Remotes")

local ClickRemote = nil
local SpinRemote = nil
local PhoneEquipRemote = nil   -- Remotes[16] — equip phone
local PhoneUpdateEvent = nil   -- Remotes[15] — server notifies new phone unlock

if RemotesFolder then
    local children = RemotesFolder:GetChildren()

    -- Find Click remote
    ClickRemote = children[2]
    if not ClickRemote or (ClickRemote.Name ~= "Click" and #children >= 2) then
        for _, child in ipairs(children) do
            if child.Name == "Click" then ClickRemote = child break end
        end
    end

    -- Find Spin remote
    SpinRemote = children[58]
    if not SpinRemote or (SpinRemote.Name ~= "Spin" and #children >= 58) then
        for _, child in ipairs(children) do
            if child.Name == "Spin" then SpinRemote = child break end
        end
    end

    -- Find phone remotes by index with name fallback
    PhoneEquipRemote = children[16]
    if not PhoneEquipRemote then
        for _, child in ipairs(children) do
            if child.Name == "Equip" or child.Name == "EquipPhone" then
                PhoneEquipRemote = child
                break
            end
        end
    end

    PhoneUpdateEvent = children[15]
    if not PhoneUpdateEvent then
        for _, child in ipairs(children) do
            if child.Name == "PhoneUpdate" or child.Name == "UpdatePhone" or child.Name == "UnlockPhone" then
                PhoneUpdateEvent = child
                break
            end
        end
    end
end

-- ============================================================================
--  FOLLOWER COUNTER READER
-- ============================================================================
local function getFollowers()
    -- Method 1: leaderstats.Followers (most reliable)
    local ok, val = pcall(function()
        local ls = LocalPlayer:FindFirstChild("leaderstats")
        if ls then
            local fol = ls:FindFirstChild("Followers")
            if fol then
                return tonumber(fol.Value) or 0
            end
        end
        return nil
    end)
    if ok and val then return val end

    -- Method 2: fallback — scan leaderstats children for anything with "Followers" in the name
    local ok2, val2 = pcall(function()
        local ls = LocalPlayer:FindFirstChild("leaderstats")
        if ls then
            for _, child in ipairs(ls:GetChildren()) do
                if child.Name:lower():find("follower") then
                    local v = tonumber(child.Value) or 0
                    if v > 0 then return v end
                end
            end
        end
        return nil
    end)
    if ok2 and val2 then return val2 end

    -- Method 3: last resort — try the old hard-coded path but use .Value not .Text
    local ok3, result = pcall(function()
        return game:GetChildren()[17]:GetChildren()[1]:GetChildren()[4]:GetChildren()[1]
    end)
    if ok3 and result then
        local num = nil
        pcall(function() num = tonumber(result.Value) end)
        if not num then
            pcall(function() num = tonumber(result.Text:gsub("[^%d]", "")) end)
        end
        return num or 0
    end

    return 0
end

-- ============================================================================
--  AUTO PHONE UPGRADE LOGIC
-- ============================================================================
local lastEquippedPhone = ""

local function equipBestPhone()
    if not PhoneEquipRemote then return end

    pcall(function()
        -- Read the PhonesController's DataCache to find owned phones & equipped
        local controller = ReplicatedStorage:FindFirstChild("Controllers")
            and ReplicatedStorage.Controllers:FindFirstChild("PhonesController")
        if not controller then return end

        local required = require(controller)
        local dataCache = nil

        -- Try to access DataCache from the module's upvalues
        -- Fallback: just read the player's equipped phone from the HUD
        -- and try equipping the next one up

        -- Method: scan for the highest phone ID the player owns
        -- by checking the Update event or using the data path
        local ok, equippedResult = pcall(function()
            return game:GetChildren()[17]:GetChildren()[1]:GetChildren()[2]:GetChildren()[15]
                :GetChildren()[1]:GetChildren()[4]:GetChildren()[11]:GetChildren()[2]
                :GetChildren()[3]:GetChildren()[1]:GetChildren()[2]
        end)

        -- Simpler approach: try to get the Phones table from cached data
        -- and find the max ID, then equip it
        local playerData = nil
        if required and required.DataCache then
            playerData = required.DataCache[LocalPlayer]
        end
        if playerData and playerData.Data then
            local data = playerData.Data
            local phones = data.Phones
            local equipped = data.EquippedPhone or ""

            if phones and type(phones) == "table" then
                -- Find highest phone ID
                local bestPhone = ""
                for _, phoneId in ipairs(phones) do
                    if phoneId ~= "" then
                        local numId = tonumber(phoneId) or 0
                        local numBest = tonumber(bestPhone) or 0
                        if numId > numBest then
                            bestPhone = phoneId
                        end
                    end
                end

                -- If we found a better phone than what's equipped, equip it
                if bestPhone ~= "" and bestPhone ~= equipped and bestPhone ~= lastEquippedPhone then
                    PhoneEquipRemote:FireServer(bestPhone)
                    lastEquippedPhone = bestPhone
                end
            end
        end
    end)
end

-- Listen for server phone unlock notifications
if PhoneUpdateEvent and PhoneUpdateEvent:IsA("RemoteEvent") then
    pcall(function()
        PhoneUpdateEvent.OnClientEvent:Connect(function(newPhoneId)
            if _G.AutofarmEnabled and PhoneEquipRemote and newPhoneId then
                task.wait(0.5) -- small delay to let server process
                PhoneEquipRemote:FireServer(tostring(newPhoneId))
                lastEquippedPhone = tostring(newPhoneId)
            end
        end)
    end)
end

