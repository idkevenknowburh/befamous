-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

-- Dynamic Remote Network Locator
local RemotesFolder = ReplicatedStorage:FindFirstChild("Utilities")
    and ReplicatedStorage.Utilities:FindFirstChild("Network")
    and ReplicatedStorage.Utilities.Network:FindFirstChild("Remotes")

local ClickRemote = nil
local SpinRemote = nil

if RemotesFolder then
    local children = RemotesFolder:GetChildren()
    ClickRemote = children[2]
    SpinRemote = children[58]
    if not ClickRemote or (ClickRemote.Name ~= "Click" and #children >= 2) then
        for _, child in ipairs(children) do
            if child.Name == "Click" then ClickRemote = child break end
        end
    end
    if not SpinRemote or (SpinRemote.Name ~= "Spin" and #children >= 58) then
        for _, child in ipairs(children) do
            if child.Name == "Spin" then SpinRemote = child break end
        end
    end
end

_G.AutofarmEnabled = false
_G.AutoSpinEnabled = false

